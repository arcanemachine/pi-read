{
  "name": "@arcanemachine/pi-read",
  "version": "0.1.0",
  "description": "Customizable read tool for Pi coding agent - configure default line/byte limits",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "watch": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write src/index.ts package.json README.md tests/*.ts",
    "test": "vitest run"
  },
  "keywords": [
    "pi",
    "pi-coding-agent",
    "extension",
    "read",
    "tool",
    "truncate",
    "pi-package"
  ],
  "pi": {
    "extensions": [
      "./src/index.ts"
    ],
    "image": "https://raw.githubusercontent.com/arcanemachine/pi-read/main/logo.jpg"
  },
  "author": "Nicholas Moen",
  "license": "MIT",
  "dependencies": {
    "@sinclair/typebox": "^0.34.49"
  },
  "devDependencies": {
    "@earendil-works/pi-coding-agent": "^0.74.0",
    "@types/node": "^25.3.0",
    "prettier": "^3.8.3",
    "typescript": "^5.7.2",
    "vitest": "^4.1.5"
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "*"
  },
  "peerDependenciesMeta": {
    "@earendil-works/pi-coding-agent": {
      "optional": true
    }
  },
  "files": [
    "src",
    "README.md",
    "LICENSE.md"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/arcanemachine/pi-read"
  },
  "homepage": "https://github.com/arcanemachine/pi-read"
}
