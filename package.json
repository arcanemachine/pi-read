{
  "name": "pi-read",
  "version": "1.0.0",
  "description": "Customizable read tool for Pi coding agent - configure default line/byte limits",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "watch": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write src/index.ts package.json README.md tests/*.ts",
    "test": "vitest run"
  },
  "keywords": [
    "pi",
    "pi-coding-agent",
    "extension",
    "read",
    "tool",
    "truncate",
    "pi-package"
  ],
  "pi": {
    "extensions": [
      "./src/index.ts"
    ]
  },
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@mariozechner/pi-coding-agent": "^0.72.1",
    "@sinclair/typebox": "^0.34.49",
    "@types/node": "^25.3.0",
    "prettier": "^3.8.3",
    "typescript": "^5.7.2",
    "vitest": "^4.1.5"
  },
  "peerDependencies": {
    "@mariozechner/pi-coding-agent": "*"
  },
  "peerDependenciesMeta": {
    "@mariozechner/pi-coding-agent": {
      "optional": true
    }
  },
  "files": [
    "src",
    "README.md",
    "LICENSE.md"
  ]
}
